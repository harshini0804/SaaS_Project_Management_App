# ==========================================
# Application Secrets & Environments
# ==========================================
# Never commit real environment variables to version control
.env
.env.*
.env.example
*.pem

# ==========================================
# Backend: Python & FastAPI
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.venv/
.env_dir/

# Testing & Coverage
.pytest_cache/
htmlcov/
.coverage
.tox/

# ==========================================
# Frontend: React, Vite & Node.js
# ==========================================
# Dependencies
node_modules/
.npm/

# Production Build Outputs
dist/
build/
out/

# Vite / React Specific
.vite/
*.tsbuildinfo

# ==========================================
# OS & Editor Specific
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs (VS Code, IntelliJ, etc.)
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Docker & Miscellaneous
# ==========================================
# Docker volumes / local data if mounted
docker/db_data/
npm-debug.log*
yarn-debug.log*
yarn-error.log*